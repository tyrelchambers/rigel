---
import { Icon } from "astro-icon/components";

const leftBehind = [
  "no YAML to hand-write",
  "no PromQL",
  "no Prometheus to run",
  "no Helm CLI",
  "no kubectl memorized",
  "no dedicated ops team",
];
---

<section
  class="relative overflow-hidden border-t border-line-subtle bg-surface"
>
  <div
    class="relative mx-auto flex max-w-[820px] flex-col items-center px-6 py-20 text-center sm:px-8 lg:py-24"
  >
    <div data-reveal class="flex items-center gap-2.5">
      <Icon name="lucide:anchor" class="size-[15px] text-fg-tertiary" />
      <span class="font-mono text-xs tracking-[0.15em] text-fg-tertiary"
        >NO BOILERPLATE</span
      >
    </div>
    <h2
      data-reveal
      class="mt-5 text-[clamp(1.85rem,3.6vw,2.5rem)] font-bold leading-[1.08] tracking-[-0.03em] text-fg"
    >
      All the parts you don't have to carry.
    </h2>
    <p
      data-reveal
      style="--reveal-delay:80ms"
      class="mt-5 max-w-[540px] text-[15.5px] leading-[1.65] text-fg-secondary"
    >
      The usual Kubernetes toolbelt stays out of your way. Rigel handles
      the machinery so you can describe what you want in plain English.
    </p>

    <div
      data-reveal
      style="--reveal-delay:140ms"
      class="mt-9 flex flex-wrap justify-center gap-2.5"
    >
      {
        leftBehind.map((c) => (
          <span class="flex items-center gap-1.5 rounded-full border border-line-strong bg-surface-elevated px-3.5 py-2 font-mono text-[12px] text-fg-secondary">
            <Icon name="lucide:ban" class="size-3 text-fg-tertiary" />
            {c}
          </span>
        ))
      }
    </div>
  </div>
</section>
