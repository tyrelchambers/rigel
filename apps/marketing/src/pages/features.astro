---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import FeaturesHero from "../components/FeaturesHero.astro";
import CapabilitySection from "../components/CapabilitySection.astro";
import ResourceMatrix from "../components/ResourceMatrix.astro";
import SecureBand from "../components/SecureBand.astro";
import DockBand from "../components/DockBand.astro";
import FinalCta from "../components/FinalCta.astro";
import Footer from "../components/Footer.astro";

const rigel = [
    {
        icon: "lucide:search",
        title: "It finds the cause",
        desc: "Ask why something's broken and it traces it through your logs, events, and the resources nearby until it lands on the actual cause.",
    },
    {
        icon: "lucide:mouse-pointer-click",
        title: "Fixes you approve",
        desc: "Every fix comes back as a button with the exact command on it. You see what it'll run before it runs.",
    },
    {
        icon: "lucide:at-sign",
        title: "Pull in any resource",
        desc: "Type @ to drop a pod, deployment, or service into the chat. Autocomplete finds it for you.",
    },
    {
        icon: "lucide:brain",
        title: "See how it got there",
        desc: "A side pane shows how it reasoned through the problem, not just the answer it landed on.",
    },
    {
        icon: "lucide:cpu",
        title: "Pick the model",
        desc: "A fast model for a quick look, a heavier one for something gnarly. You choose per question.",
    },
    {
        icon: "lucide:history",
        title: "Keeps your history",
        desc: "Past chats stick around, and any panel can hand what you're looking at to the chat with the context already loaded.",
    },
];

const nightWatch = [
    {
        icon: "lucide:shield-check",
        title: "Limits you set",
        desc: "A kill switch, the namespaces it's allowed to touch, and caps on how often it can act. It never works outside them.",
    },
    {
        icon: "lucide:siren",
        title: "Knows what to look for",
        desc: "Crash loops, OOM kills, pods stuck pending, rollouts going sideways. It catches them without you watching.",
    },
    {
        icon: "lucide:hand",
        title: "Asks when it's unsure",
        desc: "Anything it won't decide by itself goes into a Needs You queue for you to weigh in.",
    },
    {
        icon: "lucide:save",
        title: "Saves a copy first",
        desc: "It snapshots the YAML before changing anything, so nothing it does is one-way.",
    },
    {
        icon: "lucide:rotate-ccw",
        title: "Undo any action",
        desc: "Every change goes in the log with the snapshot it took right before running, and an undo button next to it.",
    },
    {
        icon: "lucide:scroll-text",
        title: "A record of everything",
        desc: "A running log of every move it's made, there whenever you want to check its work.",
    },
];

const lookout = [
    {
        icon: "lucide:message-circle",
        title: "Write it like a text",
        desc: "“Text me if postgres goes down.” This sets up an alert to notify you when postgres breaks.",
    },
    {
        icon: "lucide:smartphone",
        title: "Reaches your phone",
        desc: "Alerts come through Signal when something on your list breaks.",
    },
    {
        icon: "lucide:radar",
        title: "Runs in the background",
        desc: "Whatever you describe becomes a live watch that just keeps running.",
    },
    {
        icon: "lucide:ban",
        title: "Nothing else to run",
        desc: "No Prometheus, no Alertmanager, no dashboards to keep alive. Rigel does the watching itself.",
    },
];

const harbor = [
    {
        icon: "lucide:package",
        title: "58 apps, ready to go",
        desc: "Dev tools, databases, media, networking, observability, and more, all set up to deploy as they are.",
    },
    {
        icon: "lucide:wand-sparkles",
        title: "Walks you through it",
        desc: "It asks for the namespace, hostname, and storage, with reasonable answers already filled in.",
    },
    {
        icon: "lucide:sliders-horizontal",
        title: "Limits already set",
        desc: "Each app ships with CPU and memory settings that work, so you're not guessing at numbers you don't know yet.",
    },
    {
        icon: "lucide:refresh-cw",
        title: "Flags updates",
        desc: "Rigel watches for new versions and tells you when an app has an upgrade waiting.",
    },
    {
        icon: "lucide:trash-2",
        title: "Removes everything",
        desc: "Done with an app? It finds every piece of it, has you type the name to confirm, and clears it all out.",
    },
    {
        icon: "lucide:server",
        title: "On hardware you own",
        desc: "It all runs on your own cluster. Your data stays with you, and nothing shows up on a bill.",
    },
];

const engineRoom = [
    {
        icon: "lucide:cable",
        title: "Port-forward",
        desc: "Forward any service or pod to localhost. It notices when the port's already in use.",
    },
    {
        icon: "lucide:scroll-text",
        title: "Live logs",
        desc: "Tail pod logs as they happen, streamed straight to you. Set how far back to start.",
    },
    {
        icon: "lucide:move-vertical",
        title: "Scale and restart",
        desc: "Scale up or down, restart, pause or resume a rollout. A button for each.",
    },
    {
        icon: "lucide:pencil",
        title: "Edit env and images",
        desc: "Change environment variables, swap a container image, or adjust requests and limits in place.",
    },
    {
        icon: "lucide:server-cog",
        title: "Node operations",
        desc: "Cordon, uncordon, and drain nodes without digging up the right flags.",
    },
    {
        icon: "lucide:clock",
        title: "CronJobs",
        desc: "Suspend or resume a schedule, or trigger a run right now.",
    },
];

const charts = [
    {
        icon: "lucide:gauge",
        title: "The dashboard",
        desc: "Node, pod, and deployment health in one view, with an investigate button on anything that looks off.",
    },
    {
        icon: "lucide:waypoints",
        title: "Connectivity map",
        desc: "See how pods and services are talking, and where the traffic isn't healthy.",
    },
    {
        icon: "lucide:database",
        title: "Database radar",
        desc: "Finds your Postgres, MySQL, and Supabase instances for you. Copy a connection string, reveal credentials, or forward a port.",
    },
    {
        icon: "lucide:ruler",
        title: "Right-sizing",
        desc: "Points out workloads asking for too much or too little, and tells you what to set instead.",
    },
];
---

<Base
    title="What Rigel does"
    description="A run through everything Rigel does, from the AI that helps you find and fix cluster problems, to an agent that handles them for you, alerts you set in a sentence, a self-host catalog, and hands-on controls for every resource."
>
    <Nav />
    <main id="main">
        <FeaturesHero />

        <CapabilitySection
            id="rigel"
            variant="primary"
            eyebrow="AI CHAT"
            heading="It does the digging, you make the call."
            copy="When something breaks, you ask the chat about it. It goes digging through your logs, events, and the resources around them, then comes back with a button to fix what it found."
            items={rigel}
        />

        <CapabilitySection
            id="watch"
            variant="sunken"
            reverse
            eyebrow="AUTONOMOUS AGENT"
            heading="Install it, turn it on, and it watches for you."
            copy="It's opt-in. You deploy it into your cluster as its own service and switch it on. Once it's running, it watches your allowlisted namespaces and fixes what it knows how to handle, inside the limits you set. You decide how much it does on its own, and anything it's unsure about waits in a queue for you."
            items={nightWatch}
        />

        <CapabilitySection
            id="lookout"
            variant="primary"
            eyebrow="ALERTS"
            heading="Tell it what to watch for."
            copy="Say what you care about in a normal sentence and Rigel turns it into a watch that actually runs. When it trips, your phone buzzes. No PromQL to learn first."
            items={lookout}
        />

        <CapabilitySection
            id="harbor"
            variant="sunken"
            reverse
            eyebrow="APP CATALOG"
            heading="Self-host the things you'd usually pay for."
            copy="Pick something from the catalog and it's running on your cluster a few minutes later. The convenience of a hosted service, without the monthly invoice."
            items={harbor}
        />

        <ResourceMatrix />

        <CapabilitySection
            id="engine"
            variant="sunken"
            reverse
            eyebrow="HANDS-ON CONTROLS"
            heading="For when you'd rather just do it yourself."
            copy="AI is great until you already know exactly what you want. The everyday operations are all here as buttons, so you're not typing out kubectl or editing YAML by hand for something simple."
            items={engineRoom}
        />

        <CapabilitySection
            id="charts"
            variant="primary"
            eyebrow="CLUSTER OVERVIEW"
            heading="See where everything stands."
            copy="One place to read how the cluster's doing. Hand anything that looks wrong straight to the chat to dig into."
            items={charts}
        />

        <SecureBand />
        <DockBand />

        <FinalCta />
    </main>
    <Footer />
</Base>
