---
import { Icon } from "astro-icon/components";
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/Hero.astro";
import CrewManifest from "../components/CrewManifest.astro";
import FeaturePillar from "../components/FeaturePillar.astro";
import ShowcasePillar from "../components/ShowcasePillar.astro";
import FinalCta from "../components/FinalCta.astro";
import Footer from "../components/Footer.astro";
import ChatWindow from "../components/mocks/ChatWindow.astro";
import WatchPanel from "../components/mocks/WatchPanel.astro";
import LookoutMock from "../components/mocks/LookoutMock.astro";
import HarborMock from "../components/mocks/HarborMock.astro";

const navigatorPoints = [
    {
        icon: "lucide:search",
        text: "Automatic investigation across logs, events & dependencies",
    },
    {
        icon: "lucide:mouse-pointer-click",
        text: "Custom action buttons to increase your efficiency",
    },
];

const nightWatchPoints = [
    {
        icon: "lucide:shield-check",
        text: "Your supervisor and worker team up to keep your apps running",
    },
    {
        icon: "lucide:moon",
        text: "Non-critical issus are handled by the assistant. Critical issues are escalated to you.",
    },
];

const lookoutNegatives = ["no config", "no Prometheus", "no YAML"];

const harborFeatures = [
    "Quick deploy from a 58-app catalog",
    "No manifests to hand-write",
    "Runs on your hardware, so your data stays yours",
];
---

<Base>
    <Nav />
    <main id="main">
        <Hero />
        <CrewManifest />

        <FeaturePillar
            id="features"
            variant="primary"
            eyebrow="AI CHAT"
            heading="Your next Kubernetes assistant."
            copy="Connect an AI agent to track cluster health, diagnose issues, set up your self-hosted apps, and ensure smooth operation of your Kubernetes cluster."
            points={navigatorPoints}
        >
            <ChatWindow />
        </FeaturePillar>

        <FeaturePillar
            variant="sunken"
            reverse
            eyebrow="AUTONOMOUS AGENT"
            heading="It watches while you're away."
            copy="An in-cluster agent runs around the clock, catching drift and remediating within the guardrails you set. It helps address issues during the night to keep your apps running."
            points={nightWatchPoints}
        >
            <WatchPanel />
        </FeaturePillar>

        <ShowcasePillar
            id="lookout"
            variant="primary"
            eyebrow="SMART ALERTS"
            heading="Tell it what to worry about."
            copy={"Describe what matters: “text me if the postgres database goes down.” Rigel keeps watch and pings you the moment it happens."}
        >
            <div slot="extras" class="flex flex-wrap gap-2.5">
                {
                    lookoutNegatives.map((c) => (
                        <span class="flex items-center gap-1.5 rounded-full border border-line-strong bg-surface-elevated px-3 py-1.5 font-mono text-[11.5px] text-fg-secondary">
                            <Icon
                                name="lucide:ban"
                                class="size-3 text-fg-tertiary"
                            />
                            {c}
                        </span>
                    ))
                }
            </div>
            <LookoutMock />
        </ShowcasePillar>

        <ShowcasePillar
            id="harbor"
            variant="sunken"
            reverse
            eyebrowIcon="lucide:anchor"
            eyebrow="APP CATALOG"
            heading="Your own private cloud."
            copy={"The catalog turns “I want to self-host X” into a running app in one click, with sensible defaults and no manifests to hand-write. Host on your hardware."}
        >
            <div slot="extras" class="flex flex-col gap-3.5">
                {
                    harborFeatures.map((t) => (
                        <div class="flex items-center gap-2.5">
                            <span class="grid size-5 shrink-0 place-items-center rounded bg-running/15 text-running">
                                <Icon name="lucide:check" class="size-3" />
                            </span>
                            <span class="text-[14.5px] text-fg-secondary">
                                {t}
                            </span>
                        </div>
                    ))
                }
            </div>
            <HarborMock />
        </ShowcasePillar>

        <FinalCta />
    </main>
    <Footer />
</Base>
