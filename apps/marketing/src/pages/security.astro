---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";
import PageHeader from "../components/PageHeader.astro";
import CapabilitySection from "../components/CapabilitySection.astro";
import FinalCta from "../components/FinalCta.astro";
import Footer from "../components/Footer.astro";

const approval = [
  {
    icon: "lucide:bot",
    title: "The chat can't change anything",
    desc: "The assistant's write commands are blocked. When it finds a fix, you get a button with the exact command on it, not a change that already happened.",
  },
  {
    icon: "lucide:file-check",
    title: "You confirm every change",
    desc: "Anything that touches the cluster shows you the exact command and waits for you to say yes.",
  },
  {
    icon: "lucide:eye",
    title: "Reading and writing are separate",
    desc: "Live cluster data comes in over a read-only stream. Changes go through a different, guarded path that only you trigger.",
  },
];

const access = [
  {
    icon: "lucide:laptop",
    title: "Runs on your Mac",
    desc: "It's an app on your machine, not a server. Nothing listens on the network, so there's no public surface to attack.",
  },
  {
    icon: "lucide:plug",
    title: "Connects out, never in",
    desc: "Rigel reaches your clusters from your Mac using the kubeconfig you already have. There's no Rigel server in the middle to lock down.",
  },
  {
    icon: "lucide:shield-check",
    title: "It can only do what you can",
    desc: "Rigel acts as you. If your kubeconfig and your cluster's RBAC don't allow something, neither does Rigel.",
  },
  {
    icon: "lucide:folder-lock",
    title: "Scoped to what you're touching",
    desc: "Pick a namespace and the whole app narrows to it. Your cluster's RBAC still applies on top of that.",
  },
];

const data = [
  {
    icon: "lucide:laptop",
    title: "Local, end to end",
    desc: "Rigel runs on your Mac and uses your kubeconfig to reach your clusters directly. There's no Rigel server in between.",
  },
  {
    icon: "lucide:radar",
    title: "No telemetry",
    desc: "No analytics, no tracking, no phone-home. We don't see anything about your cluster.",
  },
  {
    icon: "lucide:cpu",
    title: "Your own AI key",
    desc: "Chat uses an AI key you provide. That's the one place your cluster's details ever leave your machine.",
  },
  {
    icon: "lucide:bell",
    title: "Notifications you run",
    desc: "Alerts go out through a Signal bridge you run yourself, not a third-party paging service.",
  },
];

const agent = [
  {
    icon: "lucide:circle-dollar-sign",
    title: "Spend cap",
    desc: "A hard dollar limit on what the agent can spend on its own.",
  },
  {
    icon: "lucide:power",
    title: "Kill-switch",
    desc: "Turn it off whenever you want. If it can't even read its own config, it shuts itself down rather than guess.",
  },
  {
    icon: "lucide:folder-lock",
    title: "Namespace-scoped",
    desc: "It only acts in the namespaces you've put on its allowlist.",
  },
  {
    icon: "lucide:save",
    title: "Backs up first",
    desc: "It snapshots a resource's YAML before changing it, so nothing it does is one-way.",
  },
  {
    icon: "lucide:rotate-ccw",
    title: "Logged, with undo",
    desc: "Every action is recorded with a before-and-after, so you can roll it back.",
  },
];

const faqs = [
  {
    q: "Does my cluster data leave my machine?",
    a: "It stays on your Mac and in your clusters. For chat, it goes to the AI provider you set up, using your own key. Update checks send just the image names you already run to public registries to spot new versions. Anything else, like GitOps to your own Git host, only happens if you turn it on. Nothing phones home.",
  },
  {
    q: "What can the AI do on its own?",
    a: "In chat, nothing that changes the cluster. Write commands are blocked, and fixes come back as buttons you approve. The optional agent can act, but only inside the spend cap, namespaces, and kill-switch you set, and it backs up and logs everything.",
  },
  {
    q: "Where are my credentials stored?",
    a: "Your kubeconfig stays right where it already lives on your Mac. The AI key you give Rigel is stored locally by the app. Rigel doesn't add its own encryption on top, so treat them like any other credential on your machine.",
  },
  {
    q: "Do I have to expose anything to the internet?",
    a: "No. Rigel is a desktop app, so there's nothing to expose. It connects out to your clusters from your Mac, and you don't open any ports or stand up a server.",
  },
];
---

<Base
  title="Security & control in Rigel"
  description="How Rigel handles access to your cluster: it runs on your Mac, asks before it changes anything, sends no telemetry, uses your own AI key, and keeps the autonomous agent inside hard limits."
>
  <Nav />
  <main id="main">
    <PageHeader
      eyebrowIcon={null}
      eyebrow="SECURITY"
      title="You stay in control."
      subtitle="Giving any tool access to your cluster is a real decision, so here's exactly how Rigel works. It runs on your own Mac, it asks before it changes anything, and it never reports back to us."
    />

    <CapabilitySection
      id="approval"
      variant="primary"
      eyebrow="APPROVAL"
      heading="Nothing changes without your say-so."
      copy="Rigel can dig through your cluster and suggest fixes, but it doesn't make the change itself. It hands you the exact command and waits for you to click."
      items={approval}
    />

    <CapabilitySection
      id="access"
      variant="sunken"
      reverse
      eyebrow="RUNS LOCALLY"
      heading="It runs on your Mac, nowhere else."
      copy="Rigel isn't a server you have to stand up and protect. It's an app on your machine that talks to your clusters directly, so there's nothing exposed to the internet."
      items={access}
    />

    <CapabilitySection
      id="data"
      variant="primary"
      eyebrow="YOUR DATA"
      heading="Your data doesn't go anywhere."
      copy="Rigel runs on your Mac. The only thing that ever leaves is what you choose to send to the AI, using your own key."
      items={data}
    />

    <CapabilitySection
      id="agent"
      variant="sunken"
      reverse
      eyebrow="AGENT GUARDRAILS"
      heading="The agent has hard limits."
      copy="The optional agent that fixes things while you're away only works inside the limits you set, and it keeps a record of everything it does."
      items={agent}
    />

    <section class="border-t border-line-subtle bg-surface">
      <div class="mx-auto max-w-[760px] px-6 py-20 sm:px-8 lg:py-24">
        <div data-reveal class="flex items-center gap-2.5">
          <span class="font-mono text-xs tracking-[0.15em] text-fg-tertiary"
            >COMMON QUESTIONS</span
          >
        </div>
        <h2
          data-reveal
          class="mt-5 text-[clamp(1.85rem,3.6vw,2.5rem)] font-bold leading-[1.08] tracking-[-0.03em] text-fg"
        >
          Questions people ask.
        </h2>

        <dl class="mt-10 flex flex-col gap-8">
          {
            faqs.map((f, i) => (
              <div data-reveal style={`--reveal-delay:${i * 50}ms`}>
                <dt class="text-[16px] font-semibold tracking-tight text-fg">
                  {f.q}
                </dt>
                <dd class="mt-2.5 text-[14.5px] leading-relaxed text-fg-secondary">
                  {f.a}
                </dd>
              </div>
            ))
          }
        </dl>
      </div>
    </section>

    <FinalCta />
  </main>
  <Footer />
</Base>
