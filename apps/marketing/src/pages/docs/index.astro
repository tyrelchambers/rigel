---
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";

const entries = (await getCollection("docs")).sort(
  (a, b) => a.data.order - b.data.order,
);
const getStarted = entries.find((e) => e.data.category === "Get started");
const guides = entries.filter((e) => e.data.category === "Guides");
---

<Base
  title="Documentation — Helmsman"
  description="Install Helmsman, then learn the panels: logs, GitOps, terminal, applying YAML, editing Deployments and Ingresses, and right-click actions."
>
  <Nav />
  <main id="main">
    <!-- hero band -->
    <section
      id="top"
      class="chart-grid relative overflow-hidden border-b border-line-subtle bg-surface-sunken"
    >
      <div
        class="glow anim-glow absolute left-1/2 top-0 size-[560px] -translate-x-1/2 opacity-[0.1]"
      >
      </div>
      <div
        class="relative mx-auto max-w-[1200px] px-6 py-20 text-center sm:px-8 lg:py-24 lg:px-12"
      >
        <div
          class="inline-flex items-center gap-2 rounded-full border border-line-strong bg-surface-elevated px-3.5 py-1.5"
        >
          <Icon name="lucide:book-open" class="size-3.5 text-accent" />
          <span class="font-mono text-[11.5px] tracking-[0.12em] text-fg-secondary"
            >DOCUMENTATION</span
          >
        </div>
        <h1
          class="mt-6 text-[clamp(2.4rem,6vw,3.5rem)] font-bold leading-[1.05] tracking-[-0.03em] text-fg"
        >
          Take the helm.
        </h1>
        <p
          class="mx-auto mt-5 max-w-[620px] text-[16.5px] leading-relaxed text-fg-secondary"
        >
          Get Helmsman running in your cluster, then learn the panels that put
          you at the wheel — logs, GitOps, the terminal, and every guarded edit.
        </p>
      </div>
    </section>

    <div class="mx-auto max-w-[1200px] px-6 py-16 sm:px-8 lg:px-12 lg:py-20">
      <!-- get started card -->
      {
        getStarted && (
          <a
            href={`/docs/${getStarted.id}`}
            class="group relative flex flex-col gap-4 overflow-hidden rounded-2xl border border-line-subtle bg-surface-elevated p-7 transition-[transform,border-color,box-shadow] duration-300 hover:-translate-y-1 hover:border-line-strong hover:shadow-[0_18px_50px_-22px_rgba(56,189,248,0.4)] sm:p-9"
          >
            <div class="glow absolute -right-16 -top-16 size-[300px] opacity-[0.08]" />
            <div class="relative flex items-start justify-between gap-4">
              <span class="grid size-12 place-items-center rounded-xl bg-accent/15 text-accent">
                <Icon name={getStarted.data.icon} class="size-6" />
              </span>
              <span class="font-mono text-[11px] tracking-[0.12em] text-fg-tertiary">
                GET STARTED
              </span>
            </div>
            <div class="relative">
              <h2 class="text-[22px] font-bold tracking-tight text-fg">
                {getStarted.data.title}
              </h2>
              <p class="mt-2 max-w-[640px] text-[14.5px] leading-relaxed text-fg-secondary">
                {getStarted.data.description}
              </p>
            </div>
            <span class="relative inline-flex items-center gap-1.5 text-[14px] font-semibold text-accent">
              Read the install guide
              <Icon
                name="lucide:arrow-right"
                class="size-4 transition-transform duration-200 group-hover:translate-x-0.5"
              />
            </span>
          </a>
        )
      }

      <!-- guides grid -->
      <div class="mt-14">
        <div class="flex items-center gap-2.5">
          <Icon name="lucide:compass" class="size-[15px] text-accent" />
          <span class="font-mono text-xs tracking-[0.15em] text-fg-tertiary"
            >GUIDES</span
          >
        </div>
        <div class="mt-6 grid gap-3.5 sm:grid-cols-2 lg:grid-cols-3">
          {
            guides.map((g) => (
              <a
                href={`/docs/${g.id}`}
                class="group flex flex-col gap-3 rounded-[12px] border border-line-subtle bg-surface-elevated p-5 transition-[transform,border-color,box-shadow] duration-300 hover:-translate-y-1 hover:border-line-strong hover:shadow-[0_10px_34px_-14px_rgba(56,189,248,0.28)]"
              >
                <span class="grid size-[34px] place-items-center rounded-lg bg-accent/15 text-accent transition-colors group-hover:bg-accent/25">
                  <Icon name={g.data.icon} class="size-[18px]" />
                </span>
                <h3 class="text-[15px] font-semibold tracking-tight text-fg">
                  {g.data.title}
                </h3>
                <p class="text-[13.5px] leading-snug text-fg-secondary">
                  {g.data.description}
                </p>
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Base>
