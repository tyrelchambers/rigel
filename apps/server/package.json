{
  "name": "@helmsman/server",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/fix-node-pty.mjs",
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --external:node-pty --outfile=dist/server.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": { "@helmsman/k8s": "workspace:*", "@helmsman/catalog": "workspace:*", "@hono/node-server": "latest", "hono": "latest", "node-pty": "1.1.0", "ws": "latest" },
  "devDependencies": { "@types/node": "latest", "@types/ws": "latest", "esbuild": "latest", "tsx": "latest", "typescript": "latest", "vitest": "^4.1.8" }
}
